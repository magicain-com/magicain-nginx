# Shared target used by all smoke/integration checks.
MAGICAIN_SMOKE_BASE_URL=https://magictensor.ai

# Local backend orchestration for frontend smoke tests.
MAGICAIN_SMOKE_BACKEND_DIR=/Users/admin/Development/github/jackjack-7/magicain/magicain-cloud
MAGICAIN_SMOKE_BACKEND_PROFILE=local
MAGICAIN_SMOKE_BACKEND_URL=http://127.0.0.1:48080
MAGICAIN_SMOKE_BACKEND_HEALTH_URL=http://127.0.0.1:48080/actuator/health
MAGICAIN_SMOKE_BACKEND_START_TIMEOUT=180
# Optional: if you started the backend yourself, set to true to skip auto-start.
# MAGICAIN_SMOKE_REUSE_BACKEND=true

# Agent tenant used by backend API integration tests and magicain-agent-ui smoke checks.
MAGICAIN_AGENT_TENANT_ID=126
MAGICAIN_AGENT_USERNAME=admin
MAGICAIN_AGENT_PASSWORD=Test1234
# Optional: skip login and use a pre-issued token instead.
# MAGICAIN_AGENT_TOKEN=

# Admin tenant used by magicain-admin-ui smoke checks.
MAGICAIN_ADMIN_TENANT_ID=1
MAGICAIN_ADMIN_USERNAME=admin
MAGICAIN_ADMIN_PASSWORD=Test1234
# Optional: skip login and use a pre-issued token instead.
# MAGICAIN_ADMIN_TOKEN=

# Optional query overrides for billing-oriented checks.
# MAGICAIN_BILLING_APP_ID=900126
# MAGICAIN_BILLING_REQUEST_ID=
# MAGICAIN_BILLING_START_DATE=2026-02-10
# MAGICAIN_BILLING_END_DATE=2026-02-12
